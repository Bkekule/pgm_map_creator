<?xml version="1.0" ?>
<!--
  Server configuration that loads the collision_map_creator plugin
  automatically. Used by the launch file so you don't need to add
  <plugin> tags to your world SDF.
-->
<server_config>
  <plugins>
    <plugin entity_name="*"
            entity_type="world"
            filename="collision_map_creator"
            name="pgm_map_creator::CollisionMapCreator">
    </plugin>
  </plugins>
</server_config>
